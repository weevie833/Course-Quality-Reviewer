# -----------------------------------------------------------------------
# Required — get your key at https://console.anthropic.com/
# -----------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Model to use for evaluations (default shown; change only if needed)
ANTHROPIC_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------
# Optional — only needed for the "Email Session" feature
# Leave blank (or remove these lines) if you don't need email.
# -----------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-address@gmail.com
# SMTP_PASSWORD=your-app-password
